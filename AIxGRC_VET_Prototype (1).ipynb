    "# Department-level readiness and risk data (matches the Module 4 wireframe mock data)\n",
    "departments = pd.DataFrame({\n",
    "    \"department\": [\"Emergency\", \"Radiology\", \"Surgery\"],\n",
    "    \"readiness_pct\": [72, 91, 88],\n",
    "    \"risk_level\": [\"HIGH\", \"LOW\", \"MODERATE\"],\n",
    "    \"risk_score\": [85, 30, 45],          # 0-100, higher = more risk, drives the risk chart\n",
    "    \"simulations_completed_pct\": [62, 94, 80],\n",
    "    \"hitl_validation_complete\": [False, True, True],\n",
    "})\n",
    "\n",
    "overall_readiness_pct = 85\n",
    "\n",
    "top_risks = pd.DataFrame({\n",
    "    \"risk\": [\"Workflow Integration\", \"Training Deficiencies\", \"Escalation Gaps\"],\n",
    "    \"department\": [\"Emergency\", \"Emergency\", \"Radiology\"],\n",
    "    \"severity\": [9, 7, 5],   # 1-10 scale, used to sort/size the risk chart\n",
    "})\n",
    "\n",
    "departments"
   ]
