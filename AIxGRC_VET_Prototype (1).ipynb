    "def generate_ai_explanation(risk_row: pd.Series) -> str:\n",
    "    '''\n",
    "    Mocked 'Ask AI Why' explanation generator (see Section 1 for why this is\n",
    "    simulated rather than a live API call).\n",
    "    '''\n",
    "    templates = {\n",
    "        \"Workflow Integration\": (\n",
    "            \"Workflow integration risk is elevated due to multiple failed simulation \"\n",
    "            \"exercises and incomplete process mapping for the EHR handoff step in \"\n",
    "            f\"{risk_row['department']} Department workflows.\"\n",
    "        ),\n",
    "        \"Training Deficiencies\": (\n",
    "            f\"Training deficiencies in {risk_row['department']} stem from a lower-than-\"\n",
    "            \"target simulation completion rate and several unresolved coaching flags.\"\n",
    "        ),\n",
    "        \"Escalation Gaps\": (\n",
    "            f\"Escalation gaps in {risk_row['department']} reflect inconsistent \"\n",
    "            \"documentation of human-in-the-loop review steps during recent simulations.\"\n",
    "        ),\n",
    "    }\n",
    "    return templates.get(risk_row[\"risk\"], \"No explanation available for this risk category.\")\n",
    "\n",
    "print(\"AI EXPLANATION (mocked) — 'Ask AI Why: Workflow Integration'\\n\")\n",
    "print(generate_ai_explanation(top_risks.iloc[0]))"
   ]
  },
