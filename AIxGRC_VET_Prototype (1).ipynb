   "source": [
    "# --- Overall Readiness Gauge (matplotlib, donut-style to mirror the wireframe circle) ---\n",
    "fig, ax = plt.subplots(figsize=(4, 4))\n",
    "\n",
    "value = overall_readiness_pct\n",
    "remainder = 100 - value\n",
    "\n",
    "ax.pie(\n",
    "    [value, remainder],\n",
    "    colors=[\"#000000\", \"#FFFFFF\"],\n",
    "    startangle=90,\n",
    "    counterclock=False,\n",
    "    wedgeprops={\"width\": 0.25, \"edgecolor\": \"black\", \"linewidth\": 1.5},\n",
    ")\n",
    "ax.text(0, 0, f\"{value}%\", ha=\"center\", va=\"center\", fontsize=28, fontweight=\"bold\")\n",
    "ax.set_title(\"Overall Readiness\", fontsize=13, fontweight=\"bold\", loc=\"left\")\n",
    "ax.set_aspect(\"equal\")\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "id": "8d2071ce",
   "metadata": {
