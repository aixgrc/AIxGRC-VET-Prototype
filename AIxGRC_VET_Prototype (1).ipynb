    "# Module 4 wireframes (solid border = static UI, dashed border = AI output)\n",
    "border = mpatches.FancyBboxPatch(\n",
    "    (0.02, 0.05), 0.96, 0.9,\n",
    "    boxstyle=\"round,pad=0.01\",\n",
    "    linewidth=1.5, edgecolor=\"black\", facecolor=\"white\", linestyle=\"dashed\",\n",
    "    transform=ax.transAxes,\n",
    ")\n",
    "ax.add_patch(border)\n",
    "\n",
    "ax.text(0.06, 0.88, \"AI EVALUATION\", fontsize=10, fontweight=\"bold\",\n",
    "        transform=ax.transAxes)\n",
    "\n",
    "y = 0.72\n",
    "ax.text(0.06, y, \"Strengths\", fontsize=11, fontweight=\"bold\", transform=ax.transAxes)\n",
    "y -= 0.13\n",
    "for s in result[\"strengths\"]:\n",
    "    ax.text(0.08, y, f\"\\u2713 {s}\", fontsize=10, transform=ax.transAxes)\n",
    "    y -= 0.11\n",
    "\n",
    "y -= 0.03\n",
    "ax.text(0.06, y, \"Needs Improvement\", fontsize=11, fontweight=\"bold\", transform=ax.transAxes)\n",
    "y -= 0.13\n",
    "for g in result[\"gaps\"]:\n",
