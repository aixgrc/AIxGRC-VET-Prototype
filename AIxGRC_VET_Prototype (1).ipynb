   ],
   "source": [
    "def generate_ai_insight(departments: pd.DataFrame, overall_pct: int) -> str:\n",
    "    '''\n",
    "    Mocked 'AI Insight' summary generator.\n",
    "\n",
    "    In production, this function would be replaced by a call to an LLM API\n",
    "    (e.g., the Anthropic API) passing in the current readiness/risk dataset\n",
    "    and asking for a short plain-language executive summary. Here, it's\n",
    "    simulated with simple Python string logic so the notebook runs without\n",
    "    any API key or network access -- see Section 1 for why this choice was made.\n",
    "    '''\n",
    "    worst = departments.sort_values(\"readiness_pct\").iloc[0]\n",
    "    blocker_reason = (\n",
    "        \"incomplete HITL validation\"\n",
    "        if not worst[\"hitl_validation_complete\"]\n",
    "        else \"below-target simulation completion\"\n",
    "    )\n",
    "    return (\n",
    "        f\"Overall readiness is {overall_pct}%. {worst['department']} Department remains \"\n",
    "        f\"the primary blocker due to {blocker_reason}.\"\n",
    "    )\n",
    "\n",
    "ai_insight_text = generate_ai_insight(departments, overall_readiness_pct)\n",
    "print(\"AI INSIGHT (mocked):\\n\")\n",
    "print(ai_insight_text)"
   ]
  },
