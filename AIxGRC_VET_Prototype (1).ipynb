   "source": [
    "# --- Department Scores bar chart (matplotlib, horizontal bars to mirror the wireframe) ---\n",
    "fig, ax = plt.subplots(figsize=(7, 3))\n",
    "\n",
    "bars = ax.barh(\n",
    "    departments[\"department\"],\n",
    "    departments[\"readiness_pct\"],\n",
    "    color=\"#AAAAAA\",\n",
    "    edgecolor=\"black\",\n",
    "    linewidth=1.5,\n",
    "    height=0.5,\n",
    ")\n",
    "\n",
    "ax.set_xlim(0, 100)\n",
    "ax.set_xlabel(\"Readiness %\")\n",
    "ax.set_title(\"Department Scores\", fontsize=13, fontweight=\"bold\", loc=\"left\")\n",
    "ax.invert_yaxis()  # Emergency on top, matching the wireframe row order\n",
    "\n",
    "for bar, pct in zip(bars, departments[\"readiness_pct\"]):\n",
    "    ax.text(pct + 2, bar.get_y() + bar.get_height() / 2, f\"{pct}%\",\n",
    "            va=\"center\", fontsize=10, fontweight=\"bold\")\n",
    "\n",
    "ax.spines[[\"top\", \"right\"]].set_visible(False)\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
